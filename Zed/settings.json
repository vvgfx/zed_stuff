  "languages": {
    "C++": {
      "semantic_tokens": "combined",
    },
  },
  "theme_overrides": {
    "Zedokai Darker (Filter Spectrum)": {
      "editor.active_line_number": "#958B9EFF",
      "editor.background": "#191919FF",
      "editor.foreground": "#C4BFC9FF",
      "editor.gutter.background": "#191919FF",
      "editor.subheader.background": "#212121FF",
      "hint": "#615E66FF",
      "link_text.hover": "#C4BFC9FF",
      "panel.background": "#212121FF",
      "syntax": {
        "attribute": {
          "color": "#4FBED1FF",
        },
        "comment": {
          "color": "#615E66FF",
        },
        "constructor": {
          "color": "#E65781FF",
        },
        "keyword": {
          "color": "#E65781FF",
        },
        "link_text": {
          "color": "#E65781FF",
        },
        "operator": {
          "color": "#E65781FF",
        },
        "property": {
          "color": "#C4BFC9FF", //C4BFC9FF
        },
        "string": {
          "color": "#E0CB5CFF",
        },
        "string.escape": {
          "color": "#C4BFC9FF",
        },
        "string.regex": {
          "color": "#E0CB5CFF",
        },
        "tag": {
          "color": "#E65781FF",
        },
        "text.literal": {
          "color": "#E0CB5CFF",
        },
        "title": {
          "color": "#E0CB5CFF",
        },
        "type": {
          "color": "#4FBED1FF",
        },
        "variable": {
          "color": "#0A7A77", //566B69FF
        },
      },
      "tab.active_background": "#191919FF",
      "tab.inactive_background": "#212121FF",
      "tab_bar.background": "#212121FF",
      "terminal.background": "#191919FF",
      "text": "#C4BFC9FF",
      "toolbar.background": "#191919FF",
      "icon": "#C4BFC9FF",
      "terminal.foreground": "#C4BFC9FF",
    },
  },
